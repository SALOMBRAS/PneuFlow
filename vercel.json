{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/mercadopago/create-preference",
      "destination": "/api/mercadopago/create-preference"
    },
    {
      "source": "/api/mercadopago/payment-status",
      "destination": "/api/mercadopago/payment-status"
    },
    {
      "source": "/api/mercadopago/payment-summary",
      "destination": "/api/mercadopago/payment-summary"
    },
    {
      "source": "/api/mercadopago/webhook",
      "destination": "/api/mercadopago/webhook"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|src/|@|node_modules/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
