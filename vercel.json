{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/mercadopago/create-preference",
      "destination": "/api/mercadopago/create-preference"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|src/|@|node_modules/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
